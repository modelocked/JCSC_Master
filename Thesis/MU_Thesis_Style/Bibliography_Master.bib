% Maynooth Harvard / biblatex master templates for Bibliography_Master.bib
% Use one model per BibLaTeX entry type present in the working .bib, plus a YouTube/video-online model.
% Keep author/editor names as Surname, Initial(s). Corporate authors must stay in double braces.
% Keep title fields in sentence case, protecting required capitals with braces: {Ireland}, {NATO}, {FPV}.
% Use date where available; year is retained for robustness with the current style file.
% Use urldate for every online source and report with a URL.

@article{MASTER_article_journal,
  author       = {Surname, A. B. and Surname, C. D.},
  title        = {Title of journal article in sentence case with {Protected Capitals}},
  journaltitle = {Journal Title in Title Case},
  year         = {2026},
  date         = {2026},
  volume       = {12},
  number       = {3},
  pages        = {45--67},
  doi          = {10.0000/example.doi}
}

@article{MASTER_article_online,
